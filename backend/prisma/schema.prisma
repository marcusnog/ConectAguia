generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Manager {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("managers")
}

model Provider {
  id                 String         @id @default(cuid())
  name               String?
  documentType       DocumentType?  @map("document_type")
  document           String?        @map("document")
  email              String         @unique
  phone              String?
  address            String?
  city               String?
  state              String?
  zipCode            String?        @map("zip_code")
  serviceType        String?        @map("service_type")
  serviceDescription String?        @map("service_description")
  extraFields        Json?          @map("extra_fields")
  status             ProviderStatus @default(PENDING)
  termsAccepted      Boolean        @map("terms_accepted")
  termsVersion       String         @map("terms_version")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  consentLogs ConsentLog[]

  @@map("providers")
}

model FormSchema {
  id          String      @id @default(cuid())
  version     Int         @default(1)
  published   Boolean     @default(false)
  publishedAt DateTime?   @map("published_at")
  fields      FormField[]
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@map("form_schemas")
}

model FormField {
  id          String     @id @default(cuid())
  schemaId    String     @map("schema_id")
  schema      FormSchema @relation(fields: [schemaId], references: [id], onDelete: Cascade)
  key         String
  label       String
  type        FieldType
  placeholder String?
  required    Boolean    @default(false)
  order       Int
  options     String[]
  minLength   Int?       @map("min_length")
  maxLength   Int?       @map("max_length")
  isCore      Boolean    @default(false) @map("is_core")
  isVisible   Boolean    @default(true) @map("is_visible")
  createdAt   DateTime   @default(now()) @map("created_at")

  @@map("form_fields")
}

enum FieldType {
  TEXT
  EMAIL
  PHONE
  NUMBER
  TEXTAREA
  SELECT
  CHECKBOX
}

model ConsentLog {
  id           String   @id @default(cuid())
  providerId   String   @map("provider_id")
  provider     Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  ip           String?
  userAgent    String?  @map("user_agent")
  termsVersion String   @map("terms_version")
  acceptedAt   DateTime @default(now()) @map("accepted_at")

  @@map("consent_logs")
}

enum DocumentType {
  CPF
  CNPJ
}

enum ProviderStatus {
  PENDING
  APPROVED
  REJECTED
  ARCHIVED
}
