DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/conectaguia?schema=public"

# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Mínimo 32 caracteres em produção
JWT_SECRET="TROQUE_POR_STRING_ALEATORIA_DE_MINIMO_64_CHARS"

JWT_EXPIRES_IN="8h"
PORT=3001
NODE_ENV=development
TERMS_VERSION="v1.0"

# Credenciais do gestor inicial (usadas em: npm run db:seed)
SEED_MANAGER_EMAIL="gestor@seudominio.com.br"
